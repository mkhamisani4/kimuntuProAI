rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Helpers =====
    function isSignedIn() {
      return request.auth != null;
    }

    // Per-user tenant model: request.auth.uid IS the tenantId.
    function ownsWrite() {
      return isSignedIn()
        && request.auth.uid == request.resource.data.tenantId
        && request.auth.uid == request.resource.data.userId;
    }

    // Existing record must already belong to the signed-in user.
    function ownsExisting() {
      return isSignedIn()
        && request.auth.uid == resource.data.tenantId;
    }

    // ===== Assistant results =====
    match /assistant_results/{resultId} {
      allow read: if ownsExisting();
      allow create: if ownsWrite();
      allow update, delete: if ownsExisting();
    }

    // ===== Usage logs =====
    // Owner can read their own logs. Writes happen from server via Admin SDK,
    // which bypasses rules; block client writes entirely.
    match /usage_logs/{usageId} {
      allow read: if ownsExisting();
      allow write: if false;
    }

    // ===== Documents (RAG / shared library) =====
    match /documents/{docId} {
      allow read: if isSignedIn();
      allow write: if false; // Server-side only via Admin SDK.
    }

    // ===== Websites =====
    match /websites/{websiteId} {
      allow read: if ownsExisting();
      allow create: if ownsWrite();
      allow update, delete: if ownsExisting();
    }

    // ===== Logos =====
    match /logos/{logoId} {
      allow read: if ownsExisting();
      allow create: if ownsWrite();
      allow update, delete: if ownsExisting();
    }

    // ===== Logo versions =====
    match /logo_versions/{versionId} {
      allow read: if ownsExisting();
      allow create: if ownsWrite();
      allow update, delete: if ownsExisting();
    }

    // ===== Email campaigns =====
    match /email_campaigns/{campaignId} {
      allow read: if ownsExisting();
      allow create: if ownsWrite();
      allow update, delete: if ownsExisting();
    }

    // ===== Email analytics events =====
    match /email_analytics/{eventId} {
      allow read: if ownsExisting();
      allow write: if false; // Server-side only (webhook + Admin SDK).
    }

    // ===== Email error logs =====
    match /email_error_log/{errorId} {
      allow read: if ownsExisting();
      allow write: if false; // Server-side only.
    }

    // ===== Marketing settings =====
    match /marketing_settings/{settingsId} {
      allow read: if ownsExisting();
      allow create: if ownsWrite();
      allow update, delete: if ownsExisting();
    }

    // ===== Marketing keywords =====
    match /marketing_keywords/{keywordId} {
      allow read: if ownsExisting();
      allow create: if ownsWrite();
      allow update, delete: if ownsExisting();
    }

    // ===== Marketing campaigns =====
    match /marketing_campaigns/{campaignId} {
      allow read: if ownsExisting();
      allow create: if ownsWrite();
      allow update, delete: if ownsExisting();
    }

    // ===== Marketing posts =====
    match /marketing_posts/{postId} {
      allow read: if ownsExisting();
      allow create: if ownsWrite();
      allow update, delete: if ownsExisting();
    }

    // ===== Keyword research history (Phase 4.1) =====
    match /keyword_research_history/{historyId} {
      allow read: if ownsExisting();
      allow create: if ownsWrite();
      allow update, delete: if ownsExisting();
    }

    // ===== Users profile =====
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false; // Profile is server-managed.
    }

    // ===== Feature flags (admin-only) =====
    match /feature_flags/{flagId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
