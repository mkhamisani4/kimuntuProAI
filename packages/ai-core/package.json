{
  "name": "@kimuntupro/ai-core",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./assistants": {
      "types": "./src/assistants/index.ts",
      "import": "./src/assistants/index.ts"
    },
    "./orchestration/planner": {
      "types": "./src/orchestration/planner.ts",
      "import": "./src/orchestration/planner.ts"
    },
    "./orchestration/executor": {
      "types": "./src/orchestration/executor.ts",
      "import": "./src/orchestration/executor.ts"
    },
    "./orchestration/middleware": {
      "types": "./src/orchestration/middleware.ts",
      "import": "./src/orchestration/middleware.ts"
    },
    "./logging": {
      "types": "./src/logging/logger.ts",
      "import": "./src/logging/logger.ts"
    },
    "./usage": {
      "types": "./src/usage/quota.ts",
      "import": "./src/usage/quota.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.0",
"tavily": "^1.0.2",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/ui": "^2.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
